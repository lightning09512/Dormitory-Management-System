package "ThongKeRepositoryImpl — 6 truy vấn JPQL" #DBEAFE {

    object "thongKeRepo : ThongKeRepositoryImpl" as TKRepo {
        ' Dùng 1 EntityManager duy nhất
        ' Thực hiện tuần tự 6 truy vấn
    }
}

package "DashboardStatsDto — Kết quả tổng hợp" #D1FAE5 {

    object "stats : DashboardStatsDto" as Stats {
        tongSinhVien        = 247
