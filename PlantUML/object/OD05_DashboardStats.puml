@startuml OD05_DashboardStats
title OD05 – Object Diagram: DashboardStatsDto Tại Thời Điểm Cụ Thể

skinparam backgroundColor #F8FAFC
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 12
skinparam objectAttributeIconSize 0

skinparam object {
    BackgroundColor #FFFFFF
    BorderColor     #94A3B8
    HeaderBackgroundColor #E2E8F0
    HeaderFontColor #0F172A
    FontColor       #1E293B
    ArrowColor      #64748B
}

skinparam note {
    BackgroundColor #FEF9C3
    BorderColor     #CA8A04
    FontColor       #1E293B
}

' ============================================================
' Kịch bản: Dashboard tải lúc 09:15 ngày 28/03/2025
