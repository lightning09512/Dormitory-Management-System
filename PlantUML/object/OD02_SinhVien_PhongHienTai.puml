package "SinhVienServiceImpl — attachPhongHienTai()" #DCFCE7 {

    object "sinhVienSvc : SinhVienServiceImpl" as SVSvc {
        sinhVienRepo = sinhVienRepoImpl
        hopDongRepo  = hopDongRepoImpl
    }
}

' ============================================================
' Relationships — luồng gán phongHienTai
' ============================================================
SVSvc --> HD1 : findBySinhVien("SV20210001")\n→ tìm HĐ trangThai = "Đang hiệu lực"
SVSvc --> HD2 : findBySinhVien("SV20210045")\n→ tìm HĐ trangThai = "Đang hiệu lực"
SVSvc --> HD3 : findBySinhVien("SV20220078")\n→ không có HĐ hiệu lực

HD1 ..> SV1 : sv.setPhongHienTai("P101")
HD2 ..> SV2 : sv.setPhongHienTai("P205")
HD3 ..> SV3 : giữ nguyên "Chưa xếp phòng"

SV1 ..> P101 : phongHienTai = maPhong
SV2 ..> P205 : phongHienTai = maPhong

note top of SV1
  phongHienTai = "P101"
  → @Transient: KHÔNG lưu DB
  → Được gán động mỗi lần load
  → Hiển thị ở cột "Phòng" trên bảng
end note

note top of SV2
  phongHienTai = "P205"
  → @Transient: KHÔNG lưu DB
  → Được gán động mỗi lần load
end note

note top of SV3
  phongHienTai = "Chưa xếp phòng"
  (default value)
  → Không có HĐ đang hiệu lực
  → Hiển thị trong ComboBox "Lập HĐ"
    để xếp phòng mới
end note

note bottom of SVSvc
  attachPhongHienTai(sv):
    sv.setPhongHienTai("Chưa xếp phòng")  // default
    hopDongRepo.findBySinhVien(sv.getMaSV())
    → filter "Đang hiệu lực"
    → sv.setPhongHienTai(hd.getMaPhong())
  ─────────────────────────────────────
  Trong LapHopDongPanel, chỉ SV3
  (phongHienTai = "Chưa xếp phòng")
  mới xuất hiện trong ComboBox
  chọn sinh viên để lập HĐ.
end note

note right of HD3
  HĐ "Đã thanh lý" → bị bỏ qua
  SV20220078 được coi là
  "Chưa xếp phòng" dù từng ở P310
end note

@enduml
