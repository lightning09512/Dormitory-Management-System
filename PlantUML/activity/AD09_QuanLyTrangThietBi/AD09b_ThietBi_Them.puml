@startuml AD09b_ThietBi_Them
title AD09b - Thêm Trang Thiết Bị Mới

skinparam ActivityBackgroundColor LightYellow
skinparam ActivityBorderColor DarkOrange
skinparam ArrowColor DarkOrange
skinparam ActivityStartColor DarkGreen
skinparam ActivityEndColor DarkRed
skinparam ActivityDiamondBackgroundColor LightBlue
skinparam ActivityDiamondBorderColor Navy

|Nhân Viên|
start
:Nhập thông tin thiết bị vào form:\n- MaTB\n- TenTB\n- GiaTri (VNĐ)\n- MaPhong;
:Chọn TinhTrang từ ComboBox\n(Tốt / Hỏng / Cần bảo trì);
:Nhấn nút "Thêm";

|Hệ Thống|
:Đọc dữ liệu từ form\n→ gọi getTrangThietBiFromForm();
:Tạo đối tượng TrangThietBi;

if (GiaTri rỗng?) then (Có)
    :Gán GiaTri = BigDecimal.ZERO;
else (Có giá trị)
    :Parse GiaTri → new BigDecimal(str);
    if (Không phải số?) then (Có)
        :Thông báo "Giá trị phải là\nmột số hợp lệ!";
        stop
    else (Hợp lệ)
    endif
endif

:Tạo đối tượng Phong tham chiếu\nvới MaPhong nhập vào\n(new Phong(); phong.setMaPhong(str));
:Gán Phong vào TrangThietBi;
:Gọi service.themThietBi(trangThietBi);

:Validate trong service:;
if (MaTB rỗng?) then (Có)
    :Thông báo "Mã thiết bị\nkhông được để trống";
    stop
else (Không rỗng)
endif

if (MaPhong rỗng?) then (Có)
    :Thông báo "Thông tin phòng\nkhông hợp lệ";
    stop
else (Không rỗng)
endif

:Kiểm tra Phong tồn tại:\nphongRepository.findById(maPhong);

if (Phòng không tồn tại?) then (Có)
    :Thông báo "Phòng không tồn tại";
    stop
else (Tồn tại)
endif

:Lấy reference Phong từ EntityManager\n(em.getReference(Phong.class, maPhong));
:Gán reference vào TrangThietBi;
:Gọi em.persist(trangThietBi);
:Thông báo "Thêm thiết bị thành công!";

|Nhân Viên|
:Xác nhận thông báo;

|Hệ Thống|
:Xóa trắng form (clearForm);
:Tải lại toàn bộ bảng thiết bị;

stop

@enduml
