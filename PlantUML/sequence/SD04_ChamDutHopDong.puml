@startuml SD04_ChamDutHopDong
title SD04 - Sequence Diagram: Chấm Dứt (Thanh Lý) Hợp Đồng

skinparam sequenceArrowThickness 2
skinparam sequenceParticipantBackgroundColor LightYellow
skinparam sequenceParticipantBorderColor DarkOrange
skinparam sequenceLifeLineBorderColor DarkOrange
skinparam sequenceGroupBackgroundColor LightBlue
skinparam noteBorderColor Navy
skinparam noteBackgroundColor LightCyan

actor "Nhân Viên" as User
participant "LapHopDongPanel\n(View)" as View
participant "HopDongController\n(Controller)" as Controller
participant "HopDongServiceImpl\n(Service)" as Service
participant "HopDongRepositoryImpl" as HDRepo
participant "PhongRepositoryImpl" as PhongRepo
database "Database\n(MySQL)" as DB

== Chọn HĐ cần thanh lý ==
User -> View : Chọn 1 dòng HĐ trong bảng
User -> View : Nhấn nút "Chấm dứt HĐ"
activate View

View -> Controller : actionPerformed(e)\n→ handleThanhLy()
activate Controller

Controller -> View : getSelectedMaHopDong()
View --> Controller : maHD (String)

alt Chưa chọn dòng nào (null)
    Controller --> View : showError("Vui lòng chọn hợp đồng\ncần thanh lý trong bảng.")
    View --> User : Hiển thị lỗi
    deactivate Controller
    deactivate View
else Đã chọn
end

== Xác nhận thanh lý ==
Controller -> View : JOptionPane.showConfirmDialog\n("Xác nhận thanh lý HĐ [maHD]?\nThao tác không thể hoàn tác.")
View --> User : Hiển thị dialog YES/NO

alt Người dùng chọn NO
    Controller --> View : (hủy thao tác)
    View --> User : Không có gì xảy ra
    deactivate Controller
    deactivate View
else Người dùng chọn YES
end

== Gọi Service thanh lý ==
Controller -> Service : thanhLyHopDong(maHD)
activate Service

== Kiểm tra HĐ tồn tại ==
Service -> HDRepo : findById(maHD)
activate HDRepo
HDRepo -> DB : SELECT * FROM HopDong\nWHERE MaHD = ?
activate DB
DB --> HDRepo : Optional<HopDong>
deactivate DB
HDRepo --> Service : Optional<HopDong>
deactivate HDRepo

alt HĐ không tồn tại (empty)
    Service --> Controller : throw IllegalArgumentException\n("Hợp đồng không tồn tại: " + maHD)
    Controller --> View : showError(message)
    View --> User : Hiển thị lỗi
    deactivate Service
    deactivate Controller
    deactivate View
else HĐ tồn tại
end

== Kiểm tra trạng thái HĐ ==
Service -> Service : hopDong.getTrangThai()

alt TrangThai != "Đang hiệu lực"
    Service --> Controller : throw IllegalStateException\n("HĐ không ở trạng thái 'Đang hiệu lực'.\nHiện tại: " + trangThai)
    Controller --> View : showError(message)
    View --> User : Hiển thị lỗi
    deactivate Service
    deactivate Controller
    deactivate View
else TrangThai = "Đang hiệu lực"
end

== Cập nhật HĐ ==
Service -> Service : hopDong.setTrangThai("Đã thanh lý")

== Lấy và cập nhật Phòng ==
Service -> PhongRepo : findById(hopDong.getMaPhong())
activate PhongRepo
PhongRepo -> DB : SELECT * FROM Phong\nWHERE MaPhong = ?
activate DB
DB --> PhongRepo : Phong
deactivate DB
PhongRepo --> Service : Phong
deactivate PhongRepo

Service -> Service : soNguoiMoi = max(0, soNguoiHienTai - 1)\nphong.setSoNguoiHienTai(soNguoiMoi)

alt soNguoiMoi < sucChua
    Service -> Service : phong.setTrangThai("Còn trống")
    note right of Service
      Phòng còn chỗ trống
      → chuyển về "Còn trống"
    end note
else soNguoiMoi == sucChua
    Service -> Service : Giữ nguyên\n"Đang sử dụng"
    note right of Service
      Vẫn còn người khác
      trong phòng → giữ nguyên
    end note
end

== Lưu xuống DB ==
Service -> HDRepo : update(hopDong)
activate HDRepo
HDRepo -> DB : BEGIN TRANSACTION
activate DB
HDRepo -> DB : UPDATE HopDong\nSET TrangThai = 'Đã thanh lý'\nWHERE MaHD = ?
DB --> HDRepo : OK
HDRepo -> DB : COMMIT
deactivate DB
HDRepo --> Service : void
deactivate HDRepo

Service -> PhongRepo : update(phong)
activate PhongRepo
PhongRepo -> DB : BEGIN TRANSACTION
activate DB
PhongRepo -> DB : UPDATE Phong\nSET SoNguoiHienTai = ?,\n    TrangThai = ?\nWHERE MaPhong = ?
DB --> PhongRepo : OK
PhongRepo -> DB : COMMIT
deactivate DB
PhongRepo --> Service : void
deactivate PhongRepo

Service --> Controller : void (thành công)
deactivate Service

== Thông báo và làm mới ==
Controller --> View : showInfo\n("Thanh lý hợp đồng [maHD] thành công.")
View --> User : Hiển thị thông báo thành công
User -> View : Nhấn OK

Controller -> Controller : refreshView()
note right of Controller
  Tải lại ComboBox (phòng trống mới)
  và bảng HĐ hiệu lực
end note
View --> User : View cập nhật
deactivate View
deactivate Controller

@enduml
