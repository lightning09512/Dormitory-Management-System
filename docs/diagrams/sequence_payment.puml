@startuml sequence_payment
actor "Nhân viên" as NV
boundary "QuanLyHoaDonPanel" as UI
control "HoaDonController" as Ctrl
entity "HoaDonService" as Svc
database "Database" as DB

NV -> UI : Chọn hóa đơn & bấm "Thanh toán"
UI -> Ctrl : thanhToan()
Ctrl -> UI : showConfirmDialog()
UI --> Ctrl : confirm = YES

Ctrl -> Svc : thanhToanHoaDon(maHD)
Svc -> DB : findByMaHDon(maHD)
DB --> Svc : hoaDonObj
Svc -> Svc : setTrangThaiThanhToan("Đã thanh toán")
Svc -> DB : save(hoaDonObj)
DB --> Svc : success

Svc --> Ctrl : void
Ctrl -> UI : showInfo("Thanh toán thành công")
Ctrl -> Ctrl : loadAll()
Ctrl -> Svc : layTatCaHoaDon()
Svc --> Ctrl : listHoaDon
Ctrl -> UI : setTableModel(listHoaDon)
UI --> NV : Giao diện cập nhật
@enduml
