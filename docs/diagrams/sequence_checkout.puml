@startuml sequence_checkout
actor "Nhân viên" as NV
boundary "LapHopDongPanel" as UI
control "HopDongController" as Ctrl
entity "HopDongService" as Svc
database "Database" as DB

NV -> UI : Chọn hợp đồng & bấm "Thanh lý"
UI -> Ctrl : handleThanhLy()
Ctrl -> UI : showConfirmDialog()
UI --> Ctrl : confirm = YES

Ctrl -> Svc : thanhLyHopDong(maHD)
Svc -> DB : findById(maHD)
DB --> Svc : hopDongObj
Svc -> Svc : validateStatus()
Svc -> DB : save(updatedHopDong)
Svc -> DB : updatePhongStatus(maPhong)
DB --> Svc : success

Svc --> Ctrl : void
Ctrl -> UI : showInfo("Thanh lý thành công")
Ctrl -> Ctrl : refreshView()
Ctrl -> UI : setHopDongList(updatedList)
UI --> NV : Giao diện cập nhật
@enduml
