@startuml sequence_billing
actor "Nhân viên" as NV
boundary "UI Ghi Điện Nước" as UI
control "HoaDonController" as Ctrl
entity "HoaDonService" as Svc
database "Database" as DB

NV -> UI : Nhập chỉ số điện, nước mới (MaPhong, Thang, Nam)
UI -> Ctrl : lapMoi()
Ctrl -> Svc : layHoaDonGanNhatTheoPhong(maPhong)
Svc -> DB : findTopByMaPhongOrderByMaHDonDesc(maPhong)
DB --> Svc : latestHoaDon (chỉ số cũ)
Ctrl -> Svc : taoHoaDon(thang, nam, maPhong, maNV, dCu, dMoi, nCu, nMoi)
Svc -> DB : save(newHoaDon)
DB --> Svc : success
Svc --> Ctrl : void
Ctrl --> UI : Hiển thị kết quả (JOptionPane)
UI --> NV : Hoàn tất
@enduml
