@startuml activity_payment
start
:Nhân viên quản lý hóa đơn;
:Chọn hóa đơn ở trạng thái 'Chưa thanh toán';
:Xác thực thông tin với sinh viên (ngoại tuyến);
:Nhấn nút "Thanh toán";
:Hệ thống yêu cầu xác nhận;
if (Admin xác nhận đã thu tiền?) then (có)
  :Hệ thống gọi nghiệp vụ Thanh toán;
  partition "Nghiệp vụ hệ thống" {
    :Kiểm tra tồn tại của hóa đơn;
    :Cập nhật trạng thái 'Đã thanh toán';
    :Lưu log giao dịch (nếu có);
  }
  :Thông báo "Thanh toán thành công";
  :Tải lại danh sách hóa đơn;
else (không)
  :Hủy bỏ;
endif
stop
@enduml
